{
  "name": "nestjs-saas-task-management-api",
  "version": "1.0.0",
  "description": "Production-inspired multi-tenant SaaS backend built with NestJS, focusing on explicit architecture, maintainable design, and thoughtful engineering trade-offs.",
  "author": "Ali Khaleghi Nasab",
  "private": false,
  "license": "MIT",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --testPathIgnorePatterns=\".(e2e|integration).spec.ts$\"",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:unit": "jest --testPathIgnorePatterns=\".(e2e|integration).spec.ts$\"",
    "test:integration": "jest -c jest.integration.config.js",
    "test:e2e": "jest -c jest.e2e.config.js",
    "typeorm": "ts-node ./node_modules/typeorm/cli",
    "migration:run": "pnpm build && pnpm typeorm migration:run -- -d ./src/modules/database/typeorm.datasource.ts",
    "migration:generate": "pnpm typeorm -- -d ./src/modules/database/typeorm.datasource.ts migration:generate ./src/$npm_config_module/migrations/$npm_config_name",
    "migration:create": "pnpm typeorm -- migration:create ./src/modules/$npm_config_module/database/migrations/$npm_config_name",
    "migration:revert": "pnpm typeorm -- -d ./src/modules/database/typeorm.datasource.ts migration:revert",
    "migration:drop": "pnpm typeorm schema:drop -- -d ./src/modules/database/typeorm.datasource.ts",
    "migration:run:prod": "node ./node_modules/typeorm/cli.js migration:run -d ./dist/src/modules/database/typeorm.datasource.js"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "8.3.0",
    "@fastify/static": "6.11.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-fastify": "10.2.6",
    "@nestjs/swagger": "^11.0.3",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "amqplib": "^1.0.3",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.1",
    "fastify": "^4.23.2",
    "joi": "^18.1.2",
    "nestjs-cls": "^6.2.1",
    "pg": "^8.20.0",
    "redis": "5.9.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "typeorm-transactional": "^0.5.0",
    "uuid": "^9.0.1",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^25.9.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-multitenancy": "file:./tools/eslint-plugin-multitenancy",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}
