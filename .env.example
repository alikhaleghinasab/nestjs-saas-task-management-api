# App
APP_NAME=Jira
APP_URL=http://localhost:3000
APP_PORT=3000
NODE_ENV=development
COOKIE_SECRET=your_seceret_here

# Swagger
SWAGGER_PATH=/api
SWAGGER_USERNAME=username
SWAGGER_PASSWORD=your_password_here
SWAGGER_TITLE=Jira
SWAGGER_DESCRIPTION=Jira

# Database
DATABASE_CONNECTION=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_DB_NAME=jira

# Auth
JWT_ACCESS_SECRET=your_seceret_here
JWT_REFRESH_SECRET=your_seceret_here
ACCESS_TOKEN_EXPIRES_IN=900
REFRESH_TOKEN_EXPIRES_IN=604800
PASSWORD_SALT_ROUNDS=10